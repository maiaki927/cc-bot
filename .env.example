# Telegram bot tokens (one per seal cat)
TELEGRAM_BOT_TOKEN_1=your-bot-1-token
TELEGRAM_BOT_TOKEN_2=your-bot-2-token
TELEGRAM_BOT_TOKEN_3=your-bot-3-token

# Shared auth token for MCP HTTP transport
MCP_AUTH_TOKEN=your-secret-auth-token

# Userbot (MTProto) — get from my.telegram.org
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=abc123def456
TELEGRAM_SESSION_STRING=your-session-string

# Monitored chat IDs (comma-separated, empty = all)
WATCHED_CHATS=
